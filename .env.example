# CRTV Configuration
# Copy to .env and adjust as needed

# LLM provider for triage: rule | medgemma | openai (CRTV_LLM_PROVIDER overrides CRTV_USE_MEDGEMMA)
# CRTV_LLM_PROVIDER=rule

# Enable LLM for triage (1 = use medgemma when CRTV_LLM_PROVIDER not set)
# CRTV_USE_MEDGEMMA=0

# MedGemma (local) - when CRTV_LLM_PROVIDER=medgemma
# MEDGEMMA_MODEL=google/medgemma-4b-it

# OpenAI-compatible API - when CRTV_LLM_PROVIDER=openai
# Install from project dir: pip install -e ".[api]"
# CRTV_OPENAI_API_KEY=sk-...
# CRTV_OPENAI_BASE_URL=   # Optional: Azure, local vLLM, etc.
# CRTV_OPENAI_MODEL=gpt-5.2
# CRTV_OPENAI_REASONING_EFFORT=medium   # GPT-5.2: none|low|medium|high|xhigh (uses Responses API)
# CRTV_OPENAI_MAX_TOKENS=8192   # Reasoning models need ~8k+ (default 8192); others use 512

# Trial mode for testing: one patient, 3 weeks (CRTV_TRIAL_MODE=0 or unset = full run)
# CRTV_TRIAL_MODE=1

# LLM response cache: same prompt -> load from disk (CRTV_LLM_CACHE=0 to disable)
# CRTV_LLM_CACHE_DIR=.llm_cache

# Prompts dir (system prompt loaded from prompts/triage_system.txt)
# CRTV_PROMPTS_DIR=./prompts

# NEST data directory (merge of app + plus tables). When set/exists, uses real data.
# CRTV_DATA_DIR=./data

# Fixtures path (for MockAdapter)
# FIXTURES_DIR=./crtv/fixtures

# Logging: INFO (default), DEBUG for full prompt/response
# CRTV_LOG_LEVEL=INFO
